---
import PortfolioLayout from '~/layouts/PortfolioLayout.astro';

interface Props {
  data: any; // You can make this more type-safe if needed
}

const { data } = Astro.props;
const { metadata, header, about, experience, projects, education, expertise, certifications, footer } = data;
---

<PortfolioLayout metadata={metadata}>
  <div class="min-h-screen bg-white">
    <div class="mx-auto max-w-7xl px-6 py-12 sm:px-8 lg:px-12 lg:py-16">
      <div class="lg:flex lg:gap-12 lg:items-start">

        <!-- Left Column - Fixed on desktop -->
        <header class="lg:w-2/5 lg:sticky lg:top-16 lg:py-8">
          <div>
            <h1 class="text-3xl font-bold tracking-tight text-gray-900 sm:text-4xl">
              {header.name}
            </h1>
            <h2 class="mt-4 text-xl font-semibold tracking-tight text-gray-700">
              {header.title}
            </h2>
            <p class="mt-6 max-w-lg text-lg leading-relaxed text-gray-600">
              {header.tagline}
            </p>

            {header.highlights && (
              <div class="mt-8 space-y-3">
                {header.highlights.map((highlight: any) => (
                  <div class="flex items-center gap-3 text-sm">
                    <svg class="h-5 w-5 text-blue-600 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                      <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
                    </svg>
                    <span class="text-gray-700"><strong>{highlight.label}</strong> - {highlight.value}</span>
                  </div>
                ))}
              </div>
            )}

            <!-- Navigation -->
            <nav class="nav hidden lg:block mt-8" aria-label="In-page jump links">
              <ul class="space-y-2">
                <li>
                  <a class="group flex items-center py-1.5" href="#about">
                    <span class="nav-indicator mr-3 h-px w-6 bg-gray-300 transition-all group-hover:w-12 group-hover:bg-blue-600 motion-reduce:transition-none"></span>
                    <span class="nav-text text-xs font-semibold uppercase tracking-wider text-gray-500 group-hover:text-blue-600">About</span>
                  </a>
                </li>
                <li>
                  <a class="group flex items-center py-1.5" href="#experience">
                    <span class="nav-indicator mr-3 h-px w-6 bg-gray-300 transition-all group-hover:w-12 group-hover:bg-blue-600 motion-reduce:transition-none"></span>
                    <span class="nav-text text-xs font-semibold uppercase tracking-wider text-gray-500 group-hover:text-blue-600">Experience</span>
                  </a>
                </li>
                <li>
                  <a class="group flex items-center py-1.5" href="#education">
                    <span class="nav-indicator mr-3 h-px w-6 bg-gray-300 transition-all group-hover:w-12 group-hover:bg-blue-600 motion-reduce:transition-none"></span>
                    <span class="nav-text text-xs font-semibold uppercase tracking-wider text-gray-500 group-hover:text-blue-600">Education</span>
                  </a>
                </li>
                <li>
                  <a class="group flex items-center py-1.5" href="#projects">
                    <span class="nav-indicator mr-3 h-px w-6 bg-gray-300 transition-all group-hover:w-12 group-hover:bg-blue-600 motion-reduce:transition-none"></span>
                    <span class="nav-text text-xs font-semibold uppercase tracking-wider text-gray-500 group-hover:text-blue-600">Projects</span>
                  </a>
                </li>
                <li>
                  <a class="group flex items-center py-1.5" href="#expertise">
                    <span class="nav-indicator mr-3 h-px w-6 bg-gray-300 transition-all group-hover:w-12 group-hover:bg-blue-600 motion-reduce:transition-none"></span>
                    <span class="nav-text text-xs font-semibold uppercase tracking-wider text-gray-500 group-hover:text-blue-600">Expertise</span>
                  </a>
                </li>
                <li>
                  <a class="group flex items-center py-1.5" href="#certifications">
                    <span class="nav-indicator mr-3 h-px w-6 bg-gray-300 transition-all group-hover:w-12 group-hover:bg-blue-600 motion-reduce:transition-none"></span>
                    <span class="nav-text text-xs font-semibold uppercase tracking-wider text-gray-500 group-hover:text-blue-600">Certifications</span>
                  </a>
                </li>
              </ul>
            </nav>

            <!-- Contact CTA -->
            <div class="mt-8">
              <a href={`mailto:${header.email}`} class="inline-flex items-center px-5 py-2.5 border border-transparent text-sm font-medium rounded-md text-white bg-blue-600 hover:bg-blue-700 transition-colors">
                Get in Touch
              </a>
            </div>
          </div>

          <!-- Social Links -->
          <ul class="mt-8 flex items-center gap-5" aria-label="Social media">
            {header.socialLinks.linkedin && (
              <li>
                <a class="block text-gray-400 hover:text-blue-600 transition-colors" href={header.socialLinks.linkedin} target="_blank" rel="noreferrer">
                  <span class="sr-only">LinkedIn</span>
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="h-6 w-6" aria-hidden="true">
                    <path d="M20.5 2h-17A1.5 1.5 0 002 3.5v17A1.5 1.5 0 003.5 22h17a1.5 1.5 0 001.5-1.5v-17A1.5 1.5 0 0020.5 2zM8 19H5v-9h3zM6.5 8.25A1.75 1.75 0 118.3 6.5a1.78 1.78 0 01-1.8 1.75zM19 19h-3v-4.74c0-1.42-.6-1.93-1.38-1.93A1.74 1.74 0 0013 14.19a.66.66 0 000 .14V19h-3v-9h2.9v1.3a3.11 3.11 0 012.7-1.4c1.55 0 3.36.86 3.36 3.66z"></path>
                  </svg>
                </a>
              </li>
            )}
            {header.socialLinks.github && (
              <li>
                <a class="block text-gray-400 hover:text-blue-600 transition-colors" href={header.socialLinks.github} target="_blank" rel="noreferrer">
                  <span class="sr-only">GitHub</span>
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="currentColor" class="h-6 w-6" aria-hidden="true">
                    <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"></path>
                  </svg>
                </a>
              </li>
            )}
            {header.socialLinks.kaggle && (
              <li>
                <a class="block text-gray-400 hover:text-blue-600 transition-colors" href={header.socialLinks.kaggle} target="_blank" rel="noreferrer">
                  <span class="sr-only">Kaggle</span>
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="h-6 w-6" aria-hidden="true">
                    <path d="M18.825 23.859c-.022.092-.117.141-.281.141h-3.139c-.187 0-.351-.082-.492-.248l-5.178-6.589-1.448 1.374v5.111c0 .235-.117.352-.351.352H5.505c-.236 0-.354-.117-.354-.352V.353c0-.233.118-.353.354-.353h2.431c.234 0 .351.12.351.353v14.343l6.203-6.272c.165-.165.33-.246.495-.246h3.239c.144 0 .236.06.285.18.046.149.034.255-.036.315l-6.555 6.344 6.836 8.507c.095.104.117.208.07.358"/>
                  </svg>
                </a>
              </li>
            )}
          </ul>
        </header>

        <!-- Right Column - Scrollable content -->
        <main class="mt-16 lg:flex-1 lg:mt-0">

          <!-- About Section -->
          <section id="about" class="mb-20 scroll-mt-20" aria-label="About">
            <div class="sticky top-0 z-20 -mx-6 mb-6 bg-white/90 px-6 py-4 backdrop-blur-sm lg:hidden">
              <h2 class="text-sm font-bold uppercase tracking-wider text-gray-900">About</h2>
            </div>
            <div class="space-y-4 text-gray-600 leading-relaxed">
              {about.map((paragraph: string) => (
                <p>{paragraph}</p>
              ))}
            </div>
          </section>

          <!-- Experience Section -->
          <section id="experience" class="mb-20 scroll-mt-20" aria-label="Work experience">
            <div class="sticky top-0 z-20 -mx-6 mb-6 bg-white/90 px-6 py-4 backdrop-blur-sm lg:hidden">
              <h2 class="text-sm font-bold uppercase tracking-wider text-gray-900">Experience</h2>
            </div>
            <div>
              <ol class="space-y-12">
                {experience.map((job: any) => (
                  <li>
                    <div class="group relative rounded-lg p-6 transition-all hover:bg-gray-50 hover:shadow-md">
                      <div class="flex items-baseline justify-between gap-4 mb-1">
                        <h3 class="text-lg font-semibold text-gray-900">
                          {job.role}
                        </h3>
                        <div class="text-sm font-medium text-gray-500 whitespace-nowrap">
                          {job.period}
                        </div>
                      </div>
                      <div class="mt-1 text-base font-medium text-blue-600">
                        {job.companyUrl ? (
                          <a href={job.companyUrl} target="_blank" rel="noreferrer" class="hover:text-blue-700 hover:underline">
                            {job.company}
                          </a>
                        ) : (
                          job.company
                        )}
                      </div>
                      <p class="mt-3 text-gray-600 leading-relaxed">{job.description}</p>
                      <ul class="mt-4 flex flex-wrap gap-2" aria-label="Technologies used">
                        {job.technologies.map((tech: string) => (
                          <li>
                            <span class="inline-flex items-center px-3 py-1 rounded-md bg-blue-50 text-sm font-medium text-blue-700">
                              {tech}
                            </span>
                          </li>
                        ))}
                      </ul>
                    </div>
                  </li>
                ))}
              </ol>
              <div class="mt-10">
                <a class="inline-flex items-center gap-2 text-blue-600 hover:text-blue-700 font-semibold group" aria-label="View Full Resume" href="/resume.pdf">
                  <span>View Full Resume</span>
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="h-5 w-5 transition-transform group-hover:translate-x-1" aria-hidden="true">
                    <path fill-rule="evenodd" d="M3 10a.75.75 0 01.75-.75h10.638L10.23 5.29a.75.75 0 111.04-1.08l5.5 5.25a.75.75 0 010 1.08l-5.5 5.25a.75.75 0 11-1.04-1.08l4.158-3.96H3.75A.75.75 0 013 10z" clip-rule="evenodd"></path>
                  </svg>
                </a>
              </div>
            </div>
          </section>

          <!-- Education Section -->
          <section id="education" class="mb-20 scroll-mt-20" aria-label="Education">
            <div class="sticky top-0 z-20 -mx-6 mb-6 bg-white/90 px-6 py-4 backdrop-blur-sm lg:hidden">
              <h2 class="text-sm font-bold uppercase tracking-wider text-gray-900">Education</h2>
            </div>
            <div class="space-y-3">
              {education.map((edu: any) => (
                <div class="flex items-baseline justify-between gap-4">
                  <div class="flex-1">
                    <span class="text-base font-semibold text-gray-900">{edu.degree}</span>
                    <span class="text-gray-600"> • </span>
                    <span class="text-base text-gray-700">{edu.institution}</span>
                  </div>
                  <span class="text-sm text-gray-500 whitespace-nowrap">{edu.year}</span>
                </div>
              ))}
            </div>
          </section>

          <!-- Projects Section -->
          <section id="projects" class="mb-20 scroll-mt-20" aria-label="Selected projects">
            <div class="sticky top-0 z-20 -mx-6 mb-6 bg-white/90 px-6 py-4 backdrop-blur-sm lg:hidden">
              <h2 class="text-sm font-bold uppercase tracking-wider text-gray-900">Projects</h2>
            </div>
            <div>
              <ul class="space-y-10">
                {projects.map((project: any) => (
                  <li>
                    <div class="group relative rounded-lg p-6 transition-all hover:bg-gray-50 hover:shadow-md">
                      <h3 class="text-lg font-semibold text-gray-900">
                        {project.title}
                      </h3>
                      {project.impact && (
                        <div class="mt-2 inline-flex items-center px-3 py-1 rounded-md bg-green-50 text-sm font-medium text-green-700">
                          {project.impact}
                        </div>
                      )}
                      <p class="mt-3 text-gray-600 leading-relaxed">{project.description}</p>
                      <ul class="mt-4 flex flex-wrap gap-2" aria-label="Technologies used">
                        {project.technologies.map((tech: string) => (
                          <li>
                            <span class="inline-flex items-center px-3 py-1 rounded-md bg-gray-100 text-sm font-medium text-gray-700">
                              {tech}
                            </span>
                          </li>
                        ))}
                      </ul>
                      {project.link && (
                        <div class="mt-4">
                          <a href={project.link} target="_blank" rel="noreferrer" class="inline-flex items-center gap-2 text-blue-600 hover:text-blue-700 text-sm font-medium">
                            <span>View Project</span>
                            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                            </svg>
                          </a>
                        </div>
                      )}
                    </div>
                  </li>
                ))}
              </ul>
            </div>
          </section>

          <!-- Expertise Section -->
          <section id="expertise" class="mb-20 scroll-mt-20" aria-label="Technical expertise">
            <div class="sticky top-0 z-20 -mx-6 mb-6 bg-white/90 px-6 py-4 backdrop-blur-sm lg:hidden">
              <h2 class="text-sm font-bold uppercase tracking-wider text-gray-900">Expertise</h2>
            </div>
            <div class="space-y-6">
              {expertise.map((area: any) => (
                <div>
                  <h3 class="text-base font-semibold text-gray-900 mb-3">
                    {area.category}
                  </h3>
                  <ul class="flex flex-wrap gap-2">
                    {area.skills.map((skill: string) => (
                      <li>
                        <span class="inline-flex items-center px-3 py-1 rounded-md bg-gray-100 text-sm text-gray-700">
                          {skill}
                        </span>
                      </li>
                    ))}
                  </ul>
                </div>
              ))}
            </div>
          </section>

          <!-- Certifications Section -->
          <section id="certifications" class="mb-20 scroll-mt-20" aria-label="Certifications">
            <div class="sticky top-0 z-20 -mx-6 mb-6 bg-white/90 px-6 py-4 backdrop-blur-sm lg:hidden">
              <h2 class="text-sm font-bold uppercase tracking-wider text-gray-900">Certifications</h2>
            </div>
            <div class="relative">
              <!-- Timeline line -->
              <div class="absolute left-[48px] top-0 bottom-0 w-0.5 bg-gray-200" aria-hidden="true"></div>

              <div class="space-y-8">
                {certifications.map((cert: any) => (
                  <div class="relative flex gap-6 items-center group">
                    <!-- Badge Image -->
                    <div class="flex-shrink-0 w-24 h-24 relative">
                      {cert.credlyUrl ? (
                        <a href={cert.credlyUrl} target="_blank" rel="noreferrer" class="block w-full h-full" aria-label={`View ${cert.name} on Credly`}>
                          <img
                            src={cert.badgeImage}
                            alt={cert.name}
                            class="w-full h-full object-contain group-hover:scale-105 transition-transform duration-200 cursor-pointer"
                            loading="lazy"
                          />
                        </a>
                      ) : (
                        <img
                          src={cert.badgeImage}
                          alt={cert.name}
                          class="w-full h-full object-contain group-hover:scale-105 transition-transform duration-200"
                          loading="lazy"
                        />
                      )}
                    </div>

                    <!-- Content -->
                    <div class="flex-1">
                      <div class="flex items-start justify-between gap-4">
                        <div>
                          <h3 class="text-base font-semibold text-gray-900 leading-tight">
                            {cert.name}
                          </h3>
                          <p class="text-sm text-gray-600 mt-1">{cert.issuer}</p>
                        </div>
                        <time class="text-sm font-medium text-blue-600 whitespace-nowrap">
                          {cert.earnedDate}
                        </time>
                      </div>
                    </div>
                  </div>
                ))}
              </div>
            </div>
          </section>

          <!-- Footer -->
          <footer class="mt-20 pt-8 border-t border-gray-200 text-sm text-gray-500">
            <p>
              © <span id="current-year">{new Date().getFullYear()}</span> {header.name}.
              {footer.text} {footer.link && (
                <a href={footer.link.url} class="text-blue-600 hover:text-blue-700 font-medium">{footer.link.text}</a>
              )}
            </p>
          </footer>
        </main>
      </div>
    </div>
  </div>

  <script>
    // Smooth scrolling for navigation links
    document.querySelectorAll('a[href^="#"]').forEach(anchor => {
      anchor.addEventListener('click', function (e) {
        e.preventDefault();
        const target = document.querySelector(this.getAttribute('href') || '');
        if (target) {
          target.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }
      });
    });

    // Active navigation highlighting based on scroll position
    const sections = document.querySelectorAll('section[id]');
    const navLinks = document.querySelectorAll('.nav a');

    function highlightNav() {
      let current = '';
      const scrollPos = window.scrollY + 150;

      sections.forEach((section) => {
        const sectionTop = section.offsetTop;
        const sectionBottom = sectionTop + section.offsetHeight;

        if (scrollPos >= sectionTop && scrollPos < sectionBottom) {
          current = section.getAttribute('id') || '';
        }
      });

      // If we're at the bottom of the page, highlight the last section
      if (window.innerHeight + window.scrollY >= document.documentElement.scrollHeight - 100) {
        const lastSection = sections[sections.length - 1];
        current = lastSection?.getAttribute('id') || '';
      }

      navLinks.forEach((link) => {
        const indicator = link.querySelector('.nav-indicator');
        const text = link.querySelector('.nav-text');
        if (link.getAttribute('href') === `#${current}`) {
          if (indicator) {
            indicator.classList.add('!w-12', '!bg-blue-600');
          }
          if (text) {
            text.classList.add('!text-blue-600');
          }
        } else {
          if (indicator) {
            indicator.classList.remove('!w-12', '!bg-blue-600');
          }
          if (text) {
            text.classList.remove('!text-blue-600');
          }
        }
      });
    }

    window.addEventListener('scroll', highlightNav);
    highlightNav();
  </script>
</PortfolioLayout>
