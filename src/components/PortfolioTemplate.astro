---
import PortfolioLayout from '~/layouts/PortfolioLayout.astro';

interface Props {
  data: any; // You can make this more type-safe if needed
}

const { data } = Astro.props;
const { metadata, header, about, experience, projects, education, expertise, certifications, footer } = data;

// Convert markdown-like syntax to HTML
function parseMarkdown(text: string): string {
  return text
    .replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>') // Bold text
    .replace(/\n/g, '<br>'); // Line breaks
}
---

<PortfolioLayout metadata={metadata}>
  <!-- Theme Toggle Button -->
  <button
    id="theme-toggle"
    type="button"
    class="fixed top-6 right-6 z-50 p-3 rounded-lg bg-white dark:bg-slate-900 border border-gray-300 dark:border-slate-700 shadow-lg hover:shadow-xl transition-all"
    aria-label="Toggle dark mode"
  >
    <svg id="theme-toggle-dark-icon" class="hidden w-5 h-5 text-gray-700" fill="currentColor" viewBox="0 0 20 20">
      <path d="M17.293 13.293A8 8 0 016.707 2.707a8.001 8.001 0 1010.586 10.586z"></path>
    </svg>
    <svg id="theme-toggle-light-icon" class="hidden w-5 h-5 text-ember" fill="currentColor" viewBox="0 0 20 20">
      <path d="M10 2a1 1 0 011 1v1a1 1 0 11-2 0V3a1 1 0 011-1zm4 8a4 4 0 11-8 0 4 4 0 018 0zm-.464 4.95l.707.707a1 1 0 001.414-1.414l-.707-.707a1 1 0 00-1.414 1.414zm2.12-10.607a1 1 0 010 1.414l-.706.707a1 1 0 11-1.414-1.414l.707-.707a1 1 0 011.414 0zM17 11a1 1 0 100-2h-1a1 1 0 100 2h1zm-7 4a1 1 0 011 1v1a1 1 0 11-2 0v-1a1 1 0 011-1zM5.05 6.464A1 1 0 106.465 5.05l-.708-.707a1 1 0 00-1.414 1.414l.707.707zm1.414 8.486l-.707.707a1 1 0 01-1.414-1.414l.707-.707a1 1 0 011.414 1.414zM4 11a1 1 0 100-2H3a1 1 0 000 2h1z" fill-rule="evenodd" clip-rule="evenodd"></path>
    </svg>
  </button>

  <div class="min-h-screen bg-coconut dark:bg-slate-950 transition-colors duration-200">
    <div class="mx-auto max-w-7xl px-6 py-12 sm:px-8 lg:px-12 lg:py-16">
      <div class="lg:flex lg:gap-12 lg:items-start">

        <!-- Left Column - Fixed on desktop -->
        <header class="lg:w-2/5 lg:sticky lg:top-16 lg:py-8">
          <div>
            <h1 class="text-3xl font-bold tracking-tight text-heading sm:text-4xl">
              {header.name}
            </h1>
            <h2 class="mt-4 text-xl font-semibold tracking-tight text-subheading">
              {header.title}
            </h2>
            <p class="mt-6 max-w-lg text-lg leading-relaxed text-body">
              {header.tagline}
            </p>

            {header.highlights && (
              <div class="mt-8 space-y-3">
                {header.highlights.map((highlight: any) => (
                  <div class="flex items-center gap-3 text-sm">
                    <svg class="h-5 w-5 text-highlight flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                      <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
                    </svg>
                    <span class="text-gray-700 dark:text-slate-200">
                      <strong class="text-gray-900 dark:text-slate-50">{highlight.label}</strong> - {highlight.link ? (
                        <a href={highlight.link} target="_blank" rel="noreferrer" class="text-ember hover:text-ember-hover dark:text-sky-400 dark:hover:text-teal-400 hover:underline transition-colors">{highlight.value}</a>
                      ) : highlight.value}
                    </span>
                  </div>
                ))}
              </div>
            )}

            <!-- Navigation -->
            <nav class="nav hidden lg:block mt-8" aria-label="In-page jump links">
              <ul class="space-y-2">
                <li>
                  <a class="group flex items-center py-1.5" href="#about">
                    <span class="nav-indicator"></span>
                    <span class="nav-text">About</span>
                  </a>
                </li>
                <li>
                  <a class="group flex items-center py-1.5" href="#experience">
                    <span class="nav-indicator"></span>
                    <span class="nav-text">Experience</span>
                  </a>
                </li>
                <li>
                  <a class="group flex items-center py-1.5" href="#education">
                    <span class="nav-indicator"></span>
                    <span class="nav-text">Education</span>
                  </a>
                </li>
                <li>
                  <a class="group flex items-center py-1.5" href="#projects">
                    <span class="nav-indicator"></span>
                    <span class="nav-text">Projects</span>
                  </a>
                </li>
                <li>
                  <a class="group flex items-center py-1.5" href="#expertise">
                    <span class="nav-indicator"></span>
                    <span class="nav-text">Expertise</span>
                  </a>
                </li>
                <li>
                  <a class="group flex items-center py-1.5" href="#certifications">
                    <span class="nav-indicator"></span>
                    <span class="nav-text">Certifications</span>
                  </a>
                </li>
              </ul>
            </nav>

            <!-- Contact CTA with Glow Effect -->
            <div class="mt-8">
              <a href={`mailto:${header.email}`} class="btn-primary">
                Get in Touch
              </a>
            </div>
          </div>

          <!-- Social Links -->
          <ul class="mt-8 flex items-center gap-5" aria-label="Social media">
            {header.socialLinks.linkedin && (
              <li>
                <a class="social-link" href={header.socialLinks.linkedin} target="_blank" rel="noreferrer">
                  <span class="sr-only">LinkedIn</span>
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="h-6 w-6" aria-hidden="true">
                    <path d="M20.5 2h-17A1.5 1.5 0 002 3.5v17A1.5 1.5 0 003.5 22h17a1.5 1.5 0 001.5-1.5v-17A1.5 1.5 0 0020.5 2zM8 19H5v-9h3zM6.5 8.25A1.75 1.75 0 118.3 6.5a1.78 1.78 0 01-1.8 1.75zM19 19h-3v-4.74c0-1.42-.6-1.93-1.38-1.93A1.74 1.74 0 0013 14.19a.66.66 0 000 .14V19h-3v-9h2.9v1.3a3.11 3.11 0 012.7-1.4c1.55 0 3.36.86 3.36 3.66z"></path>
                  </svg>
                </a>
              </li>
            )}
            {header.socialLinks.github && (
              <li>
                <a class="social-link" href={header.socialLinks.github} target="_blank" rel="noreferrer">
                  <span class="sr-only">GitHub</span>
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="currentColor" class="h-6 w-6" aria-hidden="true">
                    <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"></path>
                  </svg>
                </a>
              </li>
            )}
            {header.socialLinks.kaggle && (
              <li>
                <a class="social-link" href={header.socialLinks.kaggle} target="_blank" rel="noreferrer">
                  <span class="sr-only">Kaggle</span>
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="h-6 w-6" aria-hidden="true">
                    <path d="M18.825 23.859c-.022.092-.117.141-.281.141h-3.139c-.187 0-.351-.082-.492-.248l-5.178-6.589-1.448 1.374v5.111c0 .235-.117.352-.351.352H5.505c-.236 0-.354-.117-.354-.352V.353c0-.233.118-.353.354-.353h2.431c.234 0 .351.12.351.353v14.343l6.203-6.272c.165-.165.33-.246.495-.246h3.239c.144 0 .236.06.285.18.046.149.034.255-.036.315l-6.555 6.344 6.836 8.507c.095.104.117.208.07.358"/>
                  </svg>
                </a>
              </li>
            )}
          </ul>
        </header>

        <!-- Right Column - Scrollable content -->
        <main class="mt-16 lg:flex-1 lg:mt-0">

          <!-- About Section -->
          <section id="about" class="mb-20 scroll-mt-20" aria-label="About">
            <div class="section-header-mobile">
              <h2 class="section-header-title">About</h2>
            </div>
            <div class="space-y-4 text-body leading-relaxed">
              {about.map((paragraph: string) => (
                <p set:html={parseMarkdown(paragraph)} />
              ))}
            </div>
          </section>

          <!-- Experience Section -->
          <section id="experience" class="mb-20 scroll-mt-20" aria-label="Work experience">
            <div class="section-header-mobile">
              <h2 class="section-header-title">Experience</h2>
            </div>
            <div>
              <ol class="space-y-12">
                {experience.map((job: any) => (
                  <li>
                    <div class="group card-interactive">
                      <div class="flex items-baseline justify-between gap-4 mb-1">
                        <h3 class="text-lg font-semibold text-heading">
                          {job.role}
                        </h3>
                        <div class="text-sm font-medium text-muted whitespace-nowrap">
                          {job.period}
                        </div>
                      </div>
                      <div class="mt-1 text-base font-medium text-subheading">
                        {job.companyUrl ? (
                          <a href={job.companyUrl} target="_blank" rel="noreferrer" class="hover:text-ember-hover dark:hover:text-teal-400 hover:underline transition-colors">
                            {job.company}
                          </a>
                        ) : (
                          job.company
                        )}
                      </div>
                      <p class="mt-3 text-body leading-relaxed" set:html={parseMarkdown(job.description)} />
                      <ul class="mt-4 flex flex-wrap gap-2" aria-label="Technologies used">
                        {job.technologies.map((tech: string) => (
                          <li>
                            <span class="badge-primary">
                              {tech}
                            </span>
                          </li>
                        ))}
                      </ul>
                    </div>
                  </li>
                ))}
              </ol>
              <div class="mt-10">
                <a class="external-link" aria-label="View Full Resume" href="/resume.pdf">
                  <span>View Full Resume</span>
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="h-5 w-5 transition-transform group-hover:translate-x-1" aria-hidden="true">
                    <path fill-rule="evenodd" d="M3 10a.75.75 0 01.75-.75h10.638L10.23 5.29a.75.75 0 111.04-1.08l5.5 5.25a.75.75 0 010 1.08l-5.5 5.25a.75.75 0 11-1.04-1.08l4.158-3.96H3.75A.75.75 0 013 10z" clip-rule="evenodd"></path>
                  </svg>
                </a>
              </div>
            </div>
          </section>

          <!-- Education Section -->
          <section id="education" class="mb-20 scroll-mt-20" aria-label="Education">
            <div class="section-header-mobile">
              <h2 class="section-header-title">Education</h2>
            </div>
            <div class="space-y-6">
              {education.map((edu: any) => (
                <div class="card-static">
                  <div class="flex items-baseline justify-between gap-4">
                    <span class="text-base font-semibold text-heading">{edu.degree}</span>
                    <span class="text-sm text-muted whitespace-nowrap">{edu.year}</span>
                  </div>
                  <div class="text-base text-body mt-1">{edu.institution}</div>
                </div>
              ))}
            </div>
          </section>

          <!-- Projects Section -->
          <section id="projects" class="mb-20 scroll-mt-20" aria-label="Selected projects">
            <div class="section-header-mobile">
              <h2 class="section-header-title">Projects</h2>
            </div>
            <div>
              <ul class="space-y-10">
                {projects.map((project: any) => (
                  <li>
                    <div class="group card-interactive">
                      <h3 class="text-lg font-semibold text-gray-900 dark:text-slate-50">
                        {project.title}
                      </h3>
                      {project.impact && (
                        <div class="mt-2 badge-impact">
                          {project.impact}
                        </div>
                      )}
                      <p class="mt-3 text-body leading-relaxed" set:html={parseMarkdown(project.description)} />
                      <ul class="mt-4 flex flex-wrap gap-2" aria-label="Technologies used">
                        {project.technologies.map((tech: string) => (
                          <li>
                            <span class="badge-primary">
                              {tech}
                            </span>
                          </li>
                        ))}
                      </ul>
                      {(project.link || project.githubLink) && (
                        <div class="mt-4 flex gap-4">
                          {project.link && (
                            <a href={project.link} target="_blank" rel="noreferrer" class="external-link-sm">
                              <span>View Project</span>
                              <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                              </svg>
                            </a>
                          )}
                          {project.githubLink && (
                            <a href={project.githubLink} target="_blank" rel="noreferrer" class="external-link-sm">
                              <span>View GitHub</span>
                              <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24">
                                <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
                              </svg>
                            </a>
                          )}
                        </div>
                      )}
                    </div>
                  </li>
                ))}
              </ul>
            </div>
          </section>

          <!-- Expertise Section -->
          <section id="expertise" class="mb-20 scroll-mt-20" aria-label="Technical expertise">
            <div class="section-header-mobile">
              <h2 class="section-header-title">Expertise</h2>
            </div>
            <div class="space-y-6">
              {expertise.map((area: any) => (
                <div class="card-static">
                  <h3 class="text-base font-semibold text-subheading mb-3">
                    {area.category}
                  </h3>
                  <ul class="flex flex-wrap gap-2">
                    {area.skills.map((skill: string) => (
                      <li>
                        <span class="badge-primary">
                          {skill}
                        </span>
                      </li>
                    ))}
                  </ul>
                </div>
              ))}
            </div>
          </section>

          <!-- Certifications Section -->
          <section id="certifications" class="mb-20 scroll-mt-20" aria-label="Certifications">
            <div class="section-header-mobile">
              <h2 class="section-header-title">Certifications</h2>
            </div>
            <div class="relative">
              <!-- Timeline line -->
              <div class="absolute left-[48px] top-0 bottom-0 w-0.5 bg-fog dark:bg-slate-800" aria-hidden="true"></div>

              <div class="space-y-8">
                {certifications.map((cert: any) => (
                  <div class="relative flex gap-6 items-center group transition-colors">
                    <!-- Badge Image -->
                    <div class="flex-shrink-0 w-24 h-24 relative">
                      {cert.credlyUrl ? (
                        <a href={cert.credlyUrl} target="_blank" rel="noreferrer" class="block w-full h-full" aria-label={`View ${cert.name} on Credly`}>
                          <img
                            src={cert.badgeImage}
                            alt={cert.name}
                            class="w-full h-full object-contain group-hover:scale-105 transition-transform duration-200 cursor-pointer"
                            loading="lazy"
                          />
                        </a>
                      ) : (
                        <img
                          src={cert.badgeImage}
                          alt={cert.name}
                          class="w-full h-full object-contain group-hover:scale-105 transition-transform duration-200"
                          loading="lazy"
                        />
                      )}
                    </div>

                    <!-- Content -->
                    <div class="flex-1">
                      <div class="flex items-start justify-between gap-4">
                        <div>
                          <h3 class="text-base font-semibold text-heading leading-tight">
                            {cert.name}
                          </h3>
                          <p class="text-sm text-body mt-1">{cert.issuer}</p>
                        </div>
                        <time class="text-sm font-medium text-muted whitespace-nowrap">
                          {cert.earnedDate}
                        </time>
                      </div>
                    </div>
                  </div>
                ))}
              </div>
            </div>
          </section>

          <!-- Footer -->
          <footer class="mt-20 pt-8 border-t border-fog dark:border-slate-800 text-sm text-muted">
            <p class="whitespace-pre-line">
              {footer.text} {footer.link && (
                <a href={footer.link.url} class="text-subheading hover:text-ember-hover dark:hover:text-teal-400 font-medium transition-colors">{footer.link.text}</a>
              )}
            </p>
          </footer>
        </main>
      </div>
    </div>
  </div>

  <script>
    // Theme Toggle Functionality
    const themeToggleBtn = document.getElementById('theme-toggle');
    const themeToggleDarkIcon = document.getElementById('theme-toggle-dark-icon');
    const themeToggleLightIcon = document.getElementById('theme-toggle-light-icon');

    // Check for saved theme preference or default to light mode
    const currentTheme = localStorage.getItem('theme') || 'light';

    if (currentTheme === 'dark') {
      document.documentElement.classList.add('dark');
      themeToggleLightIcon?.classList.remove('hidden');
    } else {
      themeToggleDarkIcon?.classList.remove('hidden');
    }

    themeToggleBtn?.addEventListener('click', function() {
      // Toggle dark mode
      document.documentElement.classList.toggle('dark');

      // Update icons
      themeToggleDarkIcon?.classList.toggle('hidden');
      themeToggleLightIcon?.classList.toggle('hidden');

      // Save preference
      if (document.documentElement.classList.contains('dark')) {
        localStorage.setItem('theme', 'dark');
      } else {
        localStorage.setItem('theme', 'light');
      }
    });

    // Smooth scrolling for navigation links
    document.querySelectorAll('a[href^="#"]').forEach(anchor => {
      anchor.addEventListener('click', function (e) {
        e.preventDefault();
        const target = document.querySelector(this.getAttribute('href') || '');
        if (target) {
          target.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }
      });
    });

    // Active navigation highlighting based on scroll position
    const sections = document.querySelectorAll('section[id]');
    const navLinks = document.querySelectorAll('.nav a');

    function highlightNav() {
      let current = '';
      const scrollPos = window.scrollY + 150;

      sections.forEach((section) => {
        const sectionTop = section.offsetTop;
        const sectionBottom = sectionTop + section.offsetHeight;

        if (scrollPos >= sectionTop && scrollPos < sectionBottom) {
          current = section.getAttribute('id') || '';
        }
      });

      // If we're at the bottom of the page, highlight the last section
      if (window.innerHeight + window.scrollY >= document.documentElement.scrollHeight - 100) {
        const lastSection = sections[sections.length - 1];
        current = lastSection?.getAttribute('id') || '';
      }

      navLinks.forEach((link) => {
        const indicator = link.querySelector('.nav-indicator');
        const text = link.querySelector('.nav-text');
        if (link.getAttribute('href') === `#${current}`) {
          if (indicator) {
            indicator.classList.add('!w-12', '!bg-ember', 'dark:!bg-sky-400');
          }
          if (text) {
            text.classList.add('!text-ember', 'dark:!text-sky-400');
          }
        } else {
          if (indicator) {
            indicator.classList.remove('!w-12', '!bg-ember', 'dark:!bg-sky-400');
          }
          if (text) {
            text.classList.remove('!text-ember', 'dark:!text-sky-400');
          }
        }
      });
    }

    window.addEventListener('scroll', highlightNav);
    highlightNav();
  </script>
</PortfolioLayout>
